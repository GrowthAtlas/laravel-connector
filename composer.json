{
    "name": "growthatlas/laravel-connector",
    "description": "Official GrowthAtlas connector package for Laravel applications. Exposes the GrowthAtlas Connector API v1 endpoints to receive and publish AI-generated SEO content.",
    "type": "library",
    "license": "MIT",
    "version": "1.8.5",
    "authors": [
        {
            "name": "GrowthAtlas",
            "email": "support@growthatlas.io",
            "homepage": "https://growthatlas.io"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "GrowthAtlas\\Connector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GrowthAtlas\\Connector\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GrowthAtlas\\Connector\\ConnectorServiceProvider"
            ],
            "aliases": {
                "GrowthAtlas": "GrowthAtlas\\Connector\\Facades\\GrowthAtlas"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
